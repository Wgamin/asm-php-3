APP_NAME="Nong San Viet"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://subdomain.example.com

APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=interdata_db_name
DB_USERNAME=interdata_db_user
DB_PASSWORD=change_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=change_me
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SHIPPING_DEFAULT_PROVIDER=fast
SHIPPING_FREE_SHIPPING_THRESHOLD=300000
SHIPPING_INNER_CITY_FEE=20000
SHIPPING_STANDARD_FEE=35000
SHIPPING_BULK_FEE=10000
SHIPPING_BULK_ITEM_THRESHOLD=5
SHIPPING_FAST_ESTIMATED_DAYS=1
SHIPPING_STANDARD_ESTIMATED_DAYS=3
SHIPPING_FREE_ESTIMATED_DAYS=2

VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL="${APP_URL}/payment/vnpay-return"
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

MOMO_BASE_URL=https://test-payment.momo.vn
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REDIRECT_URL="${APP_URL}/payment/momo-return"
MOMO_IPN_URL="${APP_URL}/payment/momo/ipn"
MOMO_REQUEST_TYPE=payWithMethod
MOMO_STORE_NAME="${APP_NAME}"
MOMO_STORE_ID=nongsanviet

ZALOPAY_BASE_URL=https://sb-openapi.zalopay.vn
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_CALLBACK_URL="${APP_URL}/payment/zalopay/callback"
ZALOPAY_REDIRECT_URL="${APP_URL}/payment/zalopay-return"
ZALOPAY_BANK_CODE=
ZALOPAY_PREFERRED_PAYMENT_METHODS=domestic_card,account,international_card
ZALOPAY_EXPIRE_DURATION_SECONDS=900

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_SYSTEM_INSTRUCTION="Ban la tro ly AI cua Nong San Viet. Tra loi ngan gon, lich su, uu tien huong dan ve san pham, dat hang, thanh toan, giao hang va bao quan thuc pham. Neu can ho tro don hang cu the, hay khuyen nguoi dung mo chat voi shop."

VITE_APP_NAME="${APP_NAME}"
